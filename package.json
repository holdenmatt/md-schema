{
  "name": "md-schema",
  "version": "0.1.0",
  "private": true,
  "description": "Typed frontmatter schemas for markdown documents",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "check": "pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.0"
}
