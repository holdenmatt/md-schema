{
  "name": "@holdenmatt/md-schema",
  "version": "0.1.0",
  "description": "Typed frontmatter schemas for markdown documents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdenmatt/md-schema.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm format:check && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
